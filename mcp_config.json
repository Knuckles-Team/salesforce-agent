{
  "mcpServers": {
    "salesforce-agent": {
      "command": "uv",
      "args": [
        "run",
        "salesforce-mcp"
      ],
      "env": {
        "MCP_TOOL_MODE": "condensed",
        "ADMINTOOL": "True",
        "BULKTOOL": "True",
        "DESCRIBETOOL": "True",
        "RECORDSTOOL": "True",
        "SALESFORCETOOL": "True",
        "SALESFORCE_ACCESS_TOKEN": "",
        "SALESFORCE_ALLOW_DESTRUCTIVE": "False",
        "SALESFORCE_API_VERSION": "v62.0",
        "SALESFORCE_AUTH_FLOW": "",
        "SALESFORCE_BULK_RESULTS_MAX_BYTES": "5000000",
        "SALESFORCE_CLIENT_ID": "",
        "SALESFORCE_CLIENT_SECRET": "",
        "SALESFORCE_INSTANCE_URL": "https://yourorg.my.salesforce.com",
        "SALESFORCE_JWT_AUDIENCE": "",
        "SALESFORCE_JWT_PRIVATE_KEY": "",
        "SALESFORCE_JWT_PRIVATE_KEY_PATH": "",
        "SALESFORCE_JWT_SUBJECT": "integration.user@yourorg.com",
        "SALESFORCE_LOGIN_URL": "",
        "SALESFORCE_MAX_QUERY_RECORDS": "2000",
        "SALESFORCE_REFRESH_TOKEN": "",
        "SALESFORCE_REPORT_MAX_ROWS": "2000",
        "SALESFORCE_SANDBOX": "False",
        "SALESFORCE_TIMEOUT": "30",
        "SALESFORCE_TOKEN_TTL_SECONDS": "1800",
        "SOQLTOOL": "True"
      }
    }
  }
}
