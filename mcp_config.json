{
  "mcpServers": {
    "salesforce-agent": {
      "command": "uv",
      "args": [
        "run",
        "salesforce-mcp"
      ],
      "env": {
        "MCP_TOOL_MODE": "condensed",
        "FASTMCP_LOG_LEVEL": "<YOUR_FASTMCP_LOG_LEVEL>",
        "SALESFORCE_INSTANCE_URL": "<YOUR_SALESFORCE_INSTANCE_URL>",
        "SALESFORCE_LOGIN_URL": "<YOUR_SALESFORCE_LOGIN_URL>",
        "SALESFORCE_SANDBOX": "<YOUR_SALESFORCE_SANDBOX>",
        "SALESFORCE_API_VERSION": "<YOUR_SALESFORCE_API_VERSION>",
        "SALESFORCE_AUTH_FLOW": "<YOUR_SALESFORCE_AUTH_FLOW>",
        "SALESFORCE_CLIENT_ID": "<YOUR_SALESFORCE_CLIENT_ID>",
        "SALESFORCE_CLIENT_SECRET": "<YOUR_SALESFORCE_CLIENT_SECRET>",
        "SALESFORCE_REFRESH_TOKEN": "<YOUR_SALESFORCE_REFRESH_TOKEN>",
        "SALESFORCE_ACCESS_TOKEN": "<YOUR_SALESFORCE_ACCESS_TOKEN>",
        "SALESFORCE_JWT_SUBJECT": "<YOUR_SALESFORCE_JWT_SUBJECT>",
        "SALESFORCE_JWT_PRIVATE_KEY_PATH": "<YOUR_SALESFORCE_JWT_PRIVATE_KEY_PATH>",
        "SALESFORCE_SSL_VERIFY": "<YOUR_SALESFORCE_SSL_VERIFY>",
        "SALESFORCE_ALLOW_DESTRUCTIVE": "False",
        "SALESFORCE_MAX_QUERY_RECORDS": "2000",
        "SALESFORCE_BULK_RESULTS_MAX_BYTES": "5000000",
        "NO_COLOR": "<YOUR_NO_COLOR>",
        "TERM": "<YOUR_TERM>",
        "AGENT_DESCRIPTION": "<YOUR_AGENT_DESCRIPTION>",
        "AGENT_SYSTEM_PROMPT": "<YOUR_AGENT_SYSTEM_PROMPT>",
        "DEFAULT_AGENT_NAME": "<YOUR_DEFAULT_AGENT_NAME>",
        "MCP_URL": "<YOUR_MCP_URL>",
        "SOQLTOOL": "True",
        "RECORDSTOOL": "True",
        "DESCRIBETOOL": "True",
        "BULKTOOL": "True",
        "ADMINTOOL": "True"
      }
    }
  }
}
