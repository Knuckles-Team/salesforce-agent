# --- Connection -------------------------------------------------------------
# My Domain instance URL (required for client_credentials and static tokens)
SALESFORCE_INSTANCE_URL=https://yourorg.my.salesforce.com
# Override the OAuth login host (otherwise derived from SALESFORCE_SANDBOX)
SALESFORCE_LOGIN_URL=
# Sandbox org? true -> https://test.salesforce.com
SALESFORCE_SANDBOX=False
# REST API version
SALESFORCE_API_VERSION=v62.0
# SSL verification flag
SALESFORCE_SSL_VERIFY=True
# HTTP timeout in seconds
SALESFORCE_TIMEOUT=30

# --- Auth (pick ONE flow; auto-detected from the credentials you set) --------
# Explicit override: client_credentials | refresh_token | jwt_bearer | access_token
SALESFORCE_AUTH_FLOW=
# Connected App consumer key/secret (client_credentials, refresh_token, jwt_bearer)
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
# Refresh-token flow
SALESFORCE_REFRESH_TOKEN=
# JWT bearer flow (pip install salesforce-agent[jwt])
SALESFORCE_JWT_SUBJECT=integration.user@yourorg.com
SALESFORCE_JWT_PRIVATE_KEY=
SALESFORCE_JWT_PRIVATE_KEY_PATH=
SALESFORCE_JWT_AUDIENCE=
# Static access token (testing / short-lived sessions)
SALESFORCE_ACCESS_TOKEN=
# Cached-token TTL when the token response has no expires_in
SALESFORCE_TOKEN_TTL_SECONDS=1800

# --- Safety -------------------------------------------------------------------
# Gate for record delete, collections delete, and bulk delete/hardDelete jobs
SALESFORCE_ALLOW_DESTRUCTIVE=False
# Per-call cap on auto-paginated SOQL results
SALESFORCE_MAX_QUERY_RECORDS=2000
# Per-call cap on Bulk API 2.0 result downloads (bytes)
SALESFORCE_BULK_RESULTS_MAX_BYTES=5000000
# Synchronous report row note (Salesforce platform caps at 2000 detail rows)
SALESFORCE_REPORT_MAX_ROWS=2000
